---
// src/components/Contact.astro
import type { ContactConfig, BrandConfig } from '../lib/types';
import SectionHeader from './ui/SectionHeader.astro';
import Button from './ui/Button.astro';
import Icon from './ui/Icon.astro';

interface Props {
  data: ContactConfig;
  brand: BrandConfig;
  enrollmentUrl: string;
}

const { data, brand, enrollmentUrl } = Astro.props;

// Build personalized WhatsApp text
const encodedText = encodeURIComponent(
  `¡Hola! Vengo de su sitio web y me gustaría inscribirme y coordinar mi primer curso en ${brand.name}.`
);
const whatsappUrl = `https://api.whatsapp.com/send?phone=${data.whatsapp}&text=${encodedText}`;
---

<section id="contacto" class="contact-section">
  <div class="container">
    <SectionHeader
      title="Inicia tu Curso de Conducción Hoy"
      subtitle="Contacto e Inscripciones"
      description="¿Listo para ponerte tras el volante? Inscríbete online en minutos o escríbenos por WhatsApp para atención instantánea."
    />

    <div class="contact-grid">
      <!-- Direct Contact Methods -->
      <div class="contact-methods-card card">
        <h3 class="methods-title">¿Cómo prefieres comunicarte?</h3>
        <p class="methods-desc">Elige la opción que te sea más cómoda para coordinar valores, horarios y formas de pago.</p>

        <div class="methods-list">
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="method-item whatsapp-hover">
            <span class="method-icon whatsapp-bg flex items-center justify-center">
              <Icon name="message-circle" size={20} class="text-[#22c55e]" />
            </span>
            <div class="method-info">
              <span class="method-label">WhatsApp Directo (Atención Inmediata)</span>
              <strong class="method-value">{data.whatsapp}</strong>
            </div>
          </a>

          <a href={`tel:${data.phone.replace(/\s+/g, '')}`} class="method-item phone-hover">
            <span class="method-icon phone-bg flex items-center justify-center">
              <Icon name="phone" size={20} class="text-brand" />
            </span>
            <div class="method-info">
              <span class="method-label">Línea Telefónica</span>
              <strong class="method-value">{data.phone}</strong>
            </div>
          </a>

          <a href={`mailto:${data.email}`} class="method-item email-hover">
            <span class="method-icon email-bg flex items-center justify-center">
              <Icon name="mail" size={20} class="text-[#f97316]" />
            </span>
            <div class="method-info">
              <span class="method-label">Correo Electrónico</span>
              <strong class="method-value">{data.email}</strong>
            </div>
          </a>
        </div>
      </div>

      <!-- Quick Action Card -->
      <div class="action-highlight-card card-accent surface-hero">
        <div class="hero-bg-accent"></div>
        <div class="action-card-content">
          <span class="badge badge-accent uppercase-badge">Inscripción Express</span>
          <h3 class="action-card-title">¿Quieres empezar ya?</h3>
          <p class="action-card-desc">Completa tu matrícula 100% online en pocos minutos, o escríbenos por WhatsApp y nuestro equipo te guía en el proceso.</p>
          <div class="action-card-btn">
            <Button href={enrollmentUrl} variant="primary" size="lg">
              Inscribirme Online
            </Button>
          </div>
          <div class="action-card-btn">
            <Button href={whatsappUrl} variant="accent" size="md" whatsapp external>
              Tengo una duda
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    background-color: var(--bg-base);
    position: relative;
    overflow: hidden;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-top: var(--space-8);
  }

  @media (min-width: 1024px) {
    .contact-grid {
      grid-template-columns: repeat(2, 1fr);
      align-items: stretch;
    }
  }

  .contact-methods-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-5) var(--space-4);
    height: 100%;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .contact-methods-card {
      padding: var(--space-8);
    }
  }

  .methods-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: var(--space-2);
  }

  .methods-desc {
    font-size: 0.9375rem;
    color: #64748b;
    margin-bottom: var(--space-6);
  }

  .methods-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .method-item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4);
    background-color: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .method-item:hover {
    transform: translateX(4px);
    box-shadow: var(--shadow-md);
  }

  .whatsapp-hover:hover {
    border-color: #22c55e;
  }

  .phone-hover:hover {
    border-color: var(--color-primary);
  }

  .email-hover:hover {
    border-color: var(--color-accent);
  }

  .method-icon {
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    font-size: 1.25rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .whatsapp-bg { background-color: rgba(34, 197, 94, 0.1); }
  .phone-bg { background-color: var(--color-primary-muted); }
  .email-bg { background-color: rgba(249, 115, 22, 0.1); }

  .method-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .method-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: #64748b;
  }

  .method-value {
    font-size: 1.0625rem;
    color: #0f172a;
    word-break: break-all;
    overflow-wrap: anywhere;
  }

  .action-highlight-card {
    border-radius: var(--radius-xl);
    padding: var(--space-5) var(--space-4);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
  }

  @media (min-width: 640px) {
    .action-highlight-card {
      padding: var(--space-8);
    }
  }

  .hero-bg-accent {
    position: absolute;
    top: -50%;
    right: -50%;
    width: 150%;
    height: 150%;
    background: radial-gradient(circle, rgba(var(--color-primary), 0.3) 0%, rgba(255, 255, 255, 0) 75%);
    opacity: 0.6;
    pointer-events: none;
    z-index: 1;
  }

  .action-card-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: center;
    text-align: center;
  }

  @media (min-width: 640px) {
    .action-card-content {
      align-items: flex-start;
      text-align: left;
    }
  }

  .uppercase-badge {
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .action-card-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: #ffffff;
  }

  .action-card-desc {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.5;
  }

  .action-card-btn {
    width: 100%;
    margin-top: var(--space-2);
  }

  .action-card-btn + .action-card-btn {
    margin-top: var(--space-3);
  }

  @media (min-width: 640px) {
    .action-card-btn {
      width: auto;
    }
  }
</style>
