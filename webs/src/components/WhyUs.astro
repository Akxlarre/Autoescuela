---
// src/components/WhyUs.astro
import type { WhyUsItem, BrandConfig } from '../lib/types';
import SectionHeader from './ui/SectionHeader.astro';
import Icon from './ui/Icon.astro';

interface Props {
  data: WhyUsItem[];
  brand: BrandConfig;
}

const { data, brand } = Astro.props;
---

<section id="ventajas" class="why-us-section">
  <!-- Spotlight Glow Effect -->
  <div class="section-spotlight"></div>

  <div class="container">
    <SectionHeader
      title="¿Por qué elegir nuestra escuela?"
      subtitle="Nuestras Ventajas"
      description="Nos tomamos la seguridad vial en serio. Te preparamos con tecnología, instructores comprometidos y metodologías eficientes."
    />

    <div class="why-us-grid">
      {data.map((item, index) => (
        <div class="why-card" data-index={index}>
          <!-- Resplandor de fondo radial sutil en hover -->
          <div class="card-glow-bg"></div>
          
          <div class="card-header">
            {item.icon && (
              <div class="icon-wrapper">
                <Icon name={item.icon} class="why-icon" size={20} />
              </div>
            )}
            <h3 class="why-title">{item.title}</h3>
          </div>
          
          <div class="card-body">
            <p class="why-desc">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why-us-section {
    background: radial-gradient(120% 60% at 50% 0%, var(--bg-surface) 0%, var(--bg-base) 100%);
    position: relative;
    overflow: hidden;
  }

  /* Spotlight radial en la cabecera */
  .section-spotlight {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 350px;
    background: radial-gradient(50% 50% at 50% 0%, rgba(14, 165, 233, 0.03) 0%, transparent 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* Grilla Simétrica, Limpia y Ordenada de 3 Columnas */
  .why-us-grid {
    margin-top: var(--space-8);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    position: relative;
    z-index: 2;
  }

  /* Breakpoint para Tablet (2 columnas) */
  @media (min-width: 768px) {
    .why-us-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Breakpoint para Desktop (3 columnas perfectas y balanceadas) */
  @media (min-width: 1024px) {
    .why-us-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Tarjeta Premium Minimalista */
  .why-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    background: var(--bg-surface-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    box-shadow: 
      0 4px 12px -2px rgba(15, 23, 42, 0.02), 
      0 1px 3px -1px rgba(15, 23, 42, 0.01),
      inset 0 1px 1px rgba(255, 255, 255, 0.5);
    height: 100%;
    overflow: hidden;
    transition: 
      transform var(--transition-bounce), 
      box-shadow var(--transition-normal), 
      border-color var(--transition-normal);
  }

  /* Hover Suave y Elevación Tridimensional */
  .why-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-primary);
    box-shadow: 
      0 12px 25px -10px rgba(15, 23, 42, 0.04),
      0 0 15px 0 rgba(14, 165, 233, 0.04);
  }

  /* Borde Glowing ultrafino de 1px en Hover */
  .why-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, transparent, transparent);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    transition: background var(--transition-normal);
    z-index: 3;
  }

  .why-card:hover::after {
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  }

  /* Brillo radial de fondo en hover */
  .card-glow-bg {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(14, 165, 233, 0.015) 0%, transparent 60%);
    pointer-events: none;
    transition: transform var(--transition-slow);
    z-index: 1;
  }

  .why-card:hover .card-glow-bg {
    transform: translate(10%, 10%);
  }

  /* Cabecera de la Tarjeta (Alineación Horizontal de Icono e Info) */
  .card-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    position: relative;
    z-index: 2;
  }

  /* Icono Estilizado Compacto */
  .icon-wrapper {
    flex-shrink: 0;
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-primary-muted);
    color: var(--color-primary);
    border-radius: var(--radius-lg);
    border: 1px solid var(--brand-100);
    transition: 
      transform var(--transition-bounce), 
      background-color var(--transition-normal), 
      color var(--transition-normal);
  }

  .why-card:hover .icon-wrapper {
    transform: scale(1.04);
    background-color: var(--color-primary);
    color: white;
  }

  /* Cuerpo de la Tarjeta */
  .card-body {
    position: relative;
    z-index: 2;
  }

  /* Tipografía Limpia e Impecable */
  .why-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .why-desc {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }
</style>
