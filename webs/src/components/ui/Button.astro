---
// src/components/ui/Button.astro
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'accent' | 'glass';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  external?: boolean;
  class?: string;
  whatsapp?: boolean;
  phone?: boolean;
  id?: string;
  [key: string]: any;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  external = false,
  class: className = '',
  whatsapp = false,
  phone = false,
  id,
  ...rest
} = Astro.props;

const baseStyles = 'inline-flex items-center justify-center font-semibold rounded-lg transition-all duration-200 cursor-pointer text-center';

const variants = {
  primary: 'bg-color-primary hover:bg-color-primary-hover text-white shadow-md hover:shadow-lg focus:ring-2 focus:ring-offset-2 focus:ring-color-primary',
  secondary: 'bg-white hover:bg-slate-50 text-slate-900 border border-slate-200 shadow-sm focus:ring-2 focus:ring-offset-2 focus:ring-slate-300',
  outline: 'bg-transparent hover:bg-color-primary-muted text-color-primary border-2 border-color-primary focus:ring-2 focus:ring-offset-2 focus:ring-color-primary',
  accent: 'bg-color-accent hover:bg-color-accent-hover text-white shadow-md hover:shadow-lg focus:ring-2 focus:ring-offset-2 focus:ring-color-accent',
  glass: 'bg-white/10 hover:bg-white/20 text-white backdrop-blur border border-white/20 shadow-sm',
};

const sizes = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-5 py-2.5 text-base',
  lg: 'px-7 py-3.5 text-lg',
};

const iconClass = size === 'sm' ? 'w-4 h-4 mr-1.5' : size === 'lg' ? 'w-6 h-6 mr-2.5' : 'w-5 h-5 mr-2';

const Element = href ? 'a' : 'button';
const target = external ? '_blank' : undefined;
const rel = external ? 'noopener noreferrer' : undefined;
---

<Element
  href={href}
  class:list={[baseStyles, variants[variant], sizes[size], className]}
  target={target}
  rel={rel}
  id={id}
  {...rest}
>
  {whatsapp && (
    <svg class={iconClass} fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
    </svg>
  )}
  {phone && (
    <svg class={iconClass} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
  )}
  <slot />
</Element>

<style>
  /* Base flex utilities matching standard Tailwind to support layout since we are not loading raw Tailwind packages */
  .inline-flex { display: inline-flex; }
  .items-center { align-items: center; }
  .justify-center { justify-content: center; }
  .font-semibold { font-weight: 600; }
  .rounded-lg { border-radius: var(--radius-md); }
  .transition-all { transition-property: all; }
  .duration-200 { transition-duration: 200ms; }
  .cursor-pointer { cursor: pointer; }
  .text-center { text-align: center; }
  .shadow-md { box-shadow: var(--shadow-sm); }
  .hover\:shadow-lg:hover { box-shadow: var(--shadow-md); }
  .px-3 { padding-left: var(--space-3); padding-right: var(--space-3); }
  .py-1\.5 { padding-top: calc(var(--space-2) * 0.75); padding-bottom: calc(var(--space-2) * 0.75); }
  .px-5 { padding-left: var(--space-6); padding-right: var(--space-6); }
  .py-2\.5 { padding-top: calc(var(--space-3) * 0.85); padding-bottom: calc(var(--space-3) * 0.85); }
  .px-7 { padding-left: var(--space-8); padding-right: var(--space-8); }
  .py-3\.5 { padding-top: calc(var(--space-4) * 0.95); padding-bottom: calc(var(--space-4) * 0.95); }
  .text-sm { font-size: 0.875rem; }
  .text-base { font-size: 1rem; }
  .text-lg { font-size: 1.125rem; }
  .w-4 { width: 1rem; }
  .h-4 { height: 1rem; }
  .w-5 { width: 1.25rem; }
  .h-5 { height: 1.25rem; }
  .w-6 { width: 1.5rem; }
  .h-6 { height: 1.5rem; }
  .mr-1\.5 { margin-right: 0.375rem; }
  .mr-2 { margin-right: 0.5rem; }
  .mr-2\.5 { margin-right: 0.625rem; }
  .bg-transparent { background-color: transparent; }
  .text-white { color: #ffffff; }
  .border-2 { border-width: 2px; }
  .border { border-width: 1px; }
  .border-slate-200 { border-color: var(--border-color); }
  .text-slate-900 { color: #0f172a; }
  .bg-white { background-color: #ffffff; }
  .hover\:bg-slate-50:hover { background-color: #f8fafc; }
  .backdrop-blur { backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
  .bg-white\/10 { background-color: rgba(255, 255, 255, 0.1); }
  .hover\:bg-white\/20:hover { background-color: rgba(255, 255, 255, 0.2); }
  .border-white\/20 { border-color: rgba(255, 255, 255, 0.2); }
</style>
